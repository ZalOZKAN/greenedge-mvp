# GreenEdge-5G Configuration
# Copy this file to .env and modify as needed

# API Server
GREENEDGE_HOST=127.0.0.1
GREENEDGE_PORT=8000

# Logging
GREENEDGE_LOG_LEVEL=INFO

# Model
GREENEDGE_CONFIDENCE_THRESHOLD=0.55
GREENEDGE_POLICY_PATH=experiments/policy

# Simulator defaults
GREENEDGE_SLA_MS=120.0
GREENEDGE_EPISODE_LENGTH=50

# API Security (optional)
GREENEDGE_API_KEY=
GREENEDGE_RATE_LIMIT_PER_MINUTE=60
